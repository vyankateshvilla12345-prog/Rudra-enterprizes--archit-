# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=

# Firebase Client Configuration (Optional: Use if you prefer env vars over config files)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin Service Account (Required for server-side operations on Vercel)
FIREBASE_SERVICE_ACCOUNT_JSON=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime.
APP_URL=
